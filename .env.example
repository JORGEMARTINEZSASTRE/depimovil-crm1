# ══════════════════════════════════════════════
# DepiMóvil — Variables de entorno
# Copiar este archivo a .env y completar los valores
# NUNCA subir .env a git
# ══════════════════════════════════════════════

# ── Base de datos PostgreSQL ──────────────────
DATABASE_URL=postgresql://usuario:password@host:5432/depimovil

# ── Servidor ─────────────────────────────────
PORT=3004
NODE_ENV=production
CORS_ORIGINS=https://tudominio.com,https://portal.tudominio.com

# ── JWT ───────────────────────────────────────
JWT_SECRET=cambia-esto-por-una-clave-secreta-larga
JWT_EXPIRES=7d

# ── WhatsApp Business API (Meta) ──────────────
# Obtener en: https://developers.facebook.com → Tu App → WhatsApp → API Setup
WA_PHONE_ID=          # Phone Number ID (no es el número de teléfono)
WA_TOKEN=             # Access Token permanente
WA_VERIFY_TOKEN=depimovil-webhook-2026

# WA_MODO: 'simulacion' solo loguea mensajes (para desarrollo)
#          'produccion' envia mensajes reales por WhatsApp
WA_MODO=simulacion
