# ══════════════════════════════════════════════
# DepiMóvil — Variables de entorno
# Copiar este archivo a .env y completar los valores
# NUNCA subir .env a git
# ══════════════════════════════════════════════

# ── Base de datos PostgreSQL ──────────────────
DATABASE_URL=postgresql://usuario:password@host:5432/depimovil

# ── Servidor ─────────────────────────────────
PORT=3004
NODE_ENV=production
CORS_ORIGINS=https://tudominio.com,https://portal.tudominio.com

# ── JWT ───────────────────────────────────────
JWT_SECRET=cambia-esto-por-una-clave-secreta-larga
JWT_EXPIRES=7d

# ── WhatsApp via Evolution API (QR-based) ────────────────
# Evolution API corre como servicio aparte en Railway
# Escanear QR desde el CRM: Panel WhatsApp → "Conectar WhatsApp"

# WA_MODO: 'simulacion' solo loguea mensajes (sin enviar)
#          'produccion' envia mensajes reales via Evolution API
WA_MODO=simulacion

# URL del servicio Evolution API en Railway (sin barra final)
# Ej: https://evolution-api-production-xxxx.up.railway.app
EVOLUTION_URL=

# API Key global de Evolution API
# Se configura en Evolution con la variable AUTHENTICATION_API_KEY
EVOLUTION_KEY=

# Nombre de la instancia WhatsApp en Evolution (podés dejarlo como está)
EVOLUTION_INST=depimovil
